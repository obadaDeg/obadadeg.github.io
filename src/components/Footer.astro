---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <span>Built by Obada Daghlas</span>
    <span class="sep">·</span>
    <a href="https://github.com/obadaDeg" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
    <span class="sep">·</span>
    <a href="https://linkedin.com/in/obadadaghlas" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
    <span class="sep">·</span>
    <a href="mailto:obada.daghlas.dev@gmail.com">Email ↗</a>
    <span class="sep">·</span>
    <span>© {year}</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 1rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    flex-wrap: wrap;
  }

  .sep {
    opacity: 0.4;
  }

  a {
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--color-accent);
  }
</style>
