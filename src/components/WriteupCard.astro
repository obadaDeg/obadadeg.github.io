---
interface Props {
  title: string;
  ctf: string;
  category: string;
  difficulty: string;
  date: Date;
  slug: string;
}

const { title, ctf, category, difficulty, date, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const diffColor: Record<string, string> = {
  Easy:   '#4ade80',
  Medium: '#facc15',
  Hard:   '#f87171',
};
---

<article class="writeup-card">
  <div class="wc-main">
    <a href={`${import.meta.env.BASE_URL}writeups/${slug}`} class="wc-title">{title}</a>
    <span class="wc-ctf">{ctf}</span>
  </div>

  <div class="wc-meta">
    <span class="wc-cat">{category}</span>
    <span
      class="wc-diff"
      style={`color: ${diffColor[difficulty] ?? 'var(--color-muted)'}`}
    >{difficulty}</span>
    <time class="wc-date">{formattedDate}</time>
  </div>
</article>

<style>
  .writeup-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
    transition: padding-left 0.18s ease;
  }

  .writeup-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .writeup-card:hover {
    padding-left: 0.4rem;
  }

  .wc-main {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    min-width: 0;
  }

  .wc-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-text);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .wc-title:hover {
    color: var(--color-accent);
  }

  .wc-ctf {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    color: var(--color-muted);
  }

  .wc-meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .wc-cat {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.63rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid rgba(126, 255, 245, 0.18);
    border-radius: 3px;
  }

  .wc-diff {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
  }

  .wc-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.67rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
</style>
