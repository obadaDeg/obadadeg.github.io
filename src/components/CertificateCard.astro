---
interface Props {
  title: string;
  issuer: string;
  date: Date;
  slug: string;
  assetPath: string;
}

const { title, issuer, date, slug, assetPath } = Astro.props;

const basename = assetPath.split('/').pop()?.replace('.pdf', '') || slug;
const imagePath = `/images/certificates/${basename}.png`;
---

<article class="certificate-card">
  <a href={`/certificates/${slug}`} class="card-link-wrapper">
    <div class="card-image-container">
      <img src={imagePath} alt={`${title} Certificate`} class="card-image" loading="lazy" />
    </div>
    <div class="card-content">
      <h3 class="card-title">{title}</h3>
      <p class="card-issuer">{issuer}</p>
      <time class="card-date" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
      </time>
    </div>
  </a>
</article>

<style>
  .certificate-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease-out, box-shadow 0.2s ease-out;
  }

  .certificate-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(126, 255, 245, 0.07);
  }

  .card-link-wrapper {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    height: 100%;
  }

  .card-image-container {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #111; /* subtle placeholder while loading */
    border-bottom: 1px solid var(--color-border);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top; /* Usually certificates have logos at the top */
    transition: transform 0.3s ease;
  }

  .certificate-card:hover .card-image {
    transform: scale(1.02);
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    transition: color 0.15s ease;
  }

  .certificate-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-issuer {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: auto;
    font-family: 'IBM Plex Mono', monospace;
  }
</style>
