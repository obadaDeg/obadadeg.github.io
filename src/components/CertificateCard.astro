---
interface Props {
  title: string;
  issuer: string;
  date: Date;
  slug: string;
  assetPath: string;
  skills?: string[];
  credentialUrl?: string;
}

const { title, issuer, date, slug, assetPath, skills = [], credentialUrl } = Astro.props;

const basename = assetPath.split('/').pop()?.replace('.pdf', '') || slug;
const imagePath = `/images/certificates/${basename}.png`;
---

<article class="certificate-card">
  <a href={`/certificates/${slug}`} class="card-link-wrapper">
    <div class="card-image-container">
      <img src={imagePath} alt={`${title} Certificate`} class="card-image" loading="lazy" />
      {credentialUrl && (
        <a
          href={credentialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="verified-badge"
          title="Verified credential"
          onclick="event.stopPropagation()"
        >
          ✓ Verified
        </a>
      )}
    </div>
    <div class="card-content">
      <h3 class="card-title">{title}</h3>
      <p class="card-issuer">{issuer}</p>
      <time class="card-date" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
      </time>
      {skills.length > 0 && (
        <div class="skill-chips">
          {skills.map(skill => <span class="skill-chip">{skill}</span>)}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .certificate-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease-out, box-shadow 0.2s ease-out;
  }

  .certificate-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(126, 255, 245, 0.07);
  }

  .card-link-wrapper {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    height: 100%;
  }

  .card-image-container {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #111;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.3s ease;
  }

  .certificate-card:hover .card-image {
    transform: scale(1.02);
  }

  .verified-badge {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 4px;
    text-decoration: none;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.03em;
    transition: background 0.15s ease, color 0.15s ease;
    z-index: 1;
  }

  .verified-badge:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    transition: color 0.15s ease;
  }

  .certificate-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-issuer {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-muted);
    font-family: 'IBM Plex Mono', monospace;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .skill-chip {
    font-size: 0.68rem;
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    font-family: 'IBM Plex Mono', monospace;
  }
</style>
