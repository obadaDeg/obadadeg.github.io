---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // always trailing slash
const baseTrimmed = base.replace(/\/$/, ''); // '/obadaDeg' or ''
const strippedPath = Astro.url.pathname.replace(baseTrimmed, '') || '/';

function isActive(path: string): boolean {
  if (path === '/') return strippedPath === '/';
  return strippedPath.startsWith(path);
}

const navLinks = [
  { label: 'Projects', href: `${base}projects` },
  { label: 'Writeups', href: `${base}writeups` },
  { label: 'Blog',     href: `${base}blog` },
  { label: 'Series',   href: `${base}series` },
  { label: 'Certificates', href: `${base}certificates` },
  { label: 'Contact',  href: `${base}contact` },
];
---

<nav>
  <div class="nav-inner">
    <a href={base} class="logo">Obada Daghlas</a>

    <!-- Desktop links -->
    <div class="desktop-links">
      {navLinks.map(link => (
        <a href={link.href} class={`nav-link ${isActive(link.href) ? 'active' : ''}`}>
          {link.label}
        </a>
      ))}
      <a
        href={`${base}Obada-Daghlas-CybersecurityEngineer.pdf`}
        class="nav-link resume-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        Resume ↗
      </a>
    </div>

    <!-- Mobile hamburger (CSS-only toggle) -->
    <input type="checkbox" id="menu-toggle" class="menu-toggle" aria-hidden="true" />
    <label for="menu-toggle" class="hamburger" aria-label="Toggle navigation menu">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Mobile menu -->
    <div class="mobile-menu">
      {navLinks.map(link => (
        <a href={link.href} class={`mobile-link ${isActive(link.href) ? 'active' : ''}`}>
          {link.label}
        </a>
      ))}
      <a
        href="#"
        class="mobile-link resume-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        Resume ↗
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .logo:hover {
    color: var(--color-accent);
  }

  /* Desktop links */
  .desktop-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.15s ease;
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: '';
    display: block;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .resume-link {
    color: var(--color-muted);
  }

  /* Hamburger (hidden on desktop) */
  .menu-toggle {
    display: none;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    transition: all 0.2s ease;
  }

  /* Mobile menu (hidden by default) */
  .mobile-menu {
    display: none;
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-link {
    font-size: 0.9rem;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: var(--color-accent);
  }

  /* Mobile styles */
  @media (max-width: 640px) {
    .desktop-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    /* Show mobile menu when checkbox is checked */
    .menu-toggle:checked ~ .mobile-menu {
      display: flex;
    }

    /* Animate hamburger to X */
    .menu-toggle:checked ~ .hamburger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .menu-toggle:checked ~ .hamburger span:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle:checked ~ .hamburger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
