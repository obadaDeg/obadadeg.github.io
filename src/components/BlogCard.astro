---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  excerpt: string;
  slug: string;
}

const { title, date, tags, excerpt, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card">
  <div class="bc-top">
    <a href={`${import.meta.env.BASE_URL}blog/${slug}`} class="bc-title">{title}</a>
    <time class="bc-date">{formattedDate}</time>
  </div>

  {excerpt && <p class="bc-excerpt">{excerpt}</p>}

  {tags.length > 0 && (
    <div class="bc-tags">
      {tags.map(tag => <span class="bc-tag">{tag}</span>)}
    </div>
  )}
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: padding-left 0.18s ease;
  }

  .blog-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .blog-card:hover {
    padding-left: 0.4rem;
  }

  .bc-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .bc-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .bc-title:hover {
    color: var(--color-accent);
  }

  .bc-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.67rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .bc-excerpt {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .bc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .bc-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.63rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid rgba(126, 255, 245, 0.18);
    border-radius: 3px;
  }
</style>
