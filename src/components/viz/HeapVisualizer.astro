---
// Interactive Max-Heap Visualizer
// Drop into any MDX blog post with <HeapVisualizer />
---

<div class="hv" id="hv">
  <!-- ── Header / Controls ── -->
  <div class="hv-header">
    <div class="hv-title-row">
      <span class="hv-badge">INTERACTIVE</span>
      <span class="hv-title">Max-Heap Visualizer</span>
    </div>
    <div class="hv-controls">
      <div class="hv-insert-group">
        <input
          id="hv-val"
          class="hv-input"
          type="number"
          placeholder="1–99"
          min="1"
          max="99"
          aria-label="Value to insert"
        />
        <button id="hv-insert" class="hv-btn hv-btn--accent">Insert</button>
      </div>
      <button id="hv-extract" class="hv-btn">Extract Max</button>
      <button id="hv-fill" class="hv-btn">Quick Fill</button>
      <button id="hv-reset" class="hv-btn hv-btn--muted">Reset</button>
    </div>
  </div>

  <!-- ── Tree SVG ── -->
  <div class="hv-tree-wrap">
    <svg
      id="hv-svg"
      class="hv-svg"
      viewBox="0 0 800 310"
      preserveAspectRatio="xMidYMid meet"
      aria-label="Heap binary tree visualization"
    >
      <defs>
        <filter id="hv-glow" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="3.5" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>
      <!-- Empty state -->
      <text
        id="hv-empty-msg"
        x="400" y="155"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#6b6b80"
        font-size="13"
        font-family="IBM Plex Mono, monospace"
      >Insert values to build the heap</text>
      <g id="hv-edges"></g>
      <g id="hv-nodes"></g>
    </svg>
  </div>

  <!-- ── Array view ── -->
  <div class="hv-array-wrap">
    <span class="hv-array-label">Array <span class="hv-array-note">(1-indexed · index 0 unused)</span></span>
    <div class="hv-arr-diagram">
      <div class="hv-arr-indices" id="hv-arr-indices">
        <span class="hv-arr-idx hv-arr-idx--dummy">0</span>
      </div>
      <div class="hv-arr-cells" id="hv-arr-cells">
        <div class="hv-arr-cell hv-arr-cell--dummy">_</div>
      </div>
    </div>
  </div>

  <!-- ── Operation log ── -->
  <div class="hv-log">
    <span class="hv-log-chevron">›</span>
    <span id="hv-log-msg">Insert a value or use Quick Fill to start.</span>
  </div>
</div>

<style>
  /* ── Container ── */
  .hv {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    margin: 2.5rem 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
  }

  /* ── Header ── */
  .hv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0,0,0,0.25);
  }

  .hv-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hv-badge {
    font-size: 0.52rem;
    letter-spacing: 0.14em;
    padding: 0.12rem 0.45rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid rgba(126,255,245,0.28);
    border-radius: 3px;
  }

  .hv-title {
    font-size: 0.75rem;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }

  /* ── Controls ── */
  .hv-controls {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .hv-insert-group {
    display: flex;
    gap: 0.35rem;
  }

  .hv-input {
    width: 72px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.76rem;
    padding: 0.28rem 0.5rem;
    outline: none;
    transition: border-color 0.15s;
  }

  .hv-input:focus { border-color: var(--color-accent); }

  .hv-btn {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    padding: 0.28rem 0.7rem;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    transition: all 0.15s;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .hv-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hv-btn--accent {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .hv-btn--accent:hover:not(:disabled) {
    background: var(--color-accent) !important;
    color: var(--color-bg) !important;
  }

  .hv-btn--muted:hover:not(:disabled) {
    border-color: #ff3a5c;
    color: #ff3a5c;
  }

  .hv-btn:disabled { opacity: 0.38; cursor: not-allowed; }

  /* ── SVG tree area ── */
  .hv-tree-wrap {
    padding: 0.5rem 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hv-svg {
    width: 100%;
    display: block;
  }

  /* ── Array ── */
  .hv-array-wrap {
    padding: 0.85rem 1.25rem 1rem;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hv-array-label {
    font-size: 0.58rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hv-array-note {
    font-size: 0.54rem;
    opacity: 0.55;
    text-transform: none;
    letter-spacing: 0;
  }

  /* Diagram: indices row + cells row stacked */
  .hv-arr-diagram {
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow-x: auto;
    /* fade edges on overflow */
    mask-image: linear-gradient(to right, transparent 0%, black 2%, black 98%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 2%, black 98%, transparent 100%);
    padding: 0 2px;
  }

  /* Index row (static container — scoped OK) */
  .hv-arr-indices {
    display: flex;
    padding-bottom: 0.25rem;
  }

  /* Connected cell strip (static container — scoped OK) */
  .hv-arr-cells {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: 5px;
    overflow: hidden;
  }

  /*
   * Index labels and cells are created by JS so Astro's scoped
   * attribute is never added to them. Use :global() so the rules apply.
   */
  :global(.hv-arr-idx) {
    width: 40px;
    flex-shrink: 0;
    text-align: center;
    font-size: 0.58rem;
    color: var(--color-muted);
    font-family: 'IBM Plex Mono', monospace;
    transition: color 0.2s;
  }

  :global(.hv-arr-idx--dummy)   { color: rgba(107,107,128,0.4); }
  :global(.hv-arr-idx--active)  { color: var(--color-accent); }
  :global(.hv-arr-idx--swap)    { color: #ff3a5c; }
  :global(.hv-arr-idx--settled) { color: #4ade80; }

  :global(.hv-arr-cell) {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: 'IBM Plex Mono', monospace;
    color: var(--color-text);
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  :global(.hv-arr-cell:last-child) { border-right: none; }

  :global(.hv-arr-cell--dummy) {
    color: var(--color-muted);
    opacity: 0.38;
    font-size: 1.1rem;
  }

  :global(.hv-arr-cell--active) {
    background: rgba(126,255,245,0.1);
    color: var(--color-accent);
    border-right-color: rgba(126,255,245,0.25);
  }

  :global(.hv-arr-cell--swap) {
    background: rgba(255,58,92,0.12);
    color: #ff3a5c;
    border-right-color: rgba(255,58,92,0.25);
  }

  :global(.hv-arr-cell--settled) {
    background: rgba(74,222,128,0.1);
    color: #4ade80;
    border-right-color: rgba(74,222,128,0.25);
  }

  /* ── Log ── */
  .hv-log {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1.25rem;
    min-height: 2.4rem;
  }

  .hv-log-chevron {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  #hv-log-msg {
    color: var(--color-muted);
    font-size: 0.72rem;
    transition: color 0.2s;
    line-height: 1.4;
  }

  #hv-log-msg.hv-log--active { color: var(--color-text); }
  #hv-log-msg.hv-log--warn   { color: #facc15; }
</style>

<script>
(function () {
  /* ─── Constants ─── */
  const SVG_W    = 800;
  const NODE_R   = 22;
  const LEVEL_H  = 76;
  const TOP_PAD  = 44;
  const STEP_MS  = 580;
  const MAX_NODES = 15;

  const COL = {
    bg:       '#0a0a0f',
    surface:  '#111118',
    border:   '#1e1e2e',
    text:     '#e2e2e8',
    muted:    '#6b6b80',
    accent:   '#7efff5',
    red:      '#ff3a5c',
    green:    '#4ade80',
  };

  /* ─── State ─── */
  let heap: number[] = [0]; // 1-indexed; heap[0] unused
  let animating = false;

  /* ─── DOM refs ─── */
  const edgesG    = document.getElementById('hv-edges')!;
  const nodesG    = document.getElementById('hv-nodes')!;
  const emptyMsg   = document.getElementById('hv-empty-msg')!;
  const arrIndices = document.getElementById('hv-arr-indices')!;
  const arrCells   = document.getElementById('hv-arr-cells')!;
  const logMsg    = document.getElementById('hv-log-msg')!;
  const insertBtn = document.getElementById('hv-insert') as HTMLButtonElement;
  const extractBtn = document.getElementById('hv-extract') as HTMLButtonElement;
  const fillBtn   = document.getElementById('hv-fill') as HTMLButtonElement;
  const resetBtn  = document.getElementById('hv-reset') as HTMLButtonElement;
  const valInput  = document.getElementById('hv-val') as HTMLInputElement;

  /* ─── SVG helpers ─── */
  const ns = 'http://www.w3.org/2000/svg';
  const svgEl = (tag: string) => document.createElementNS(ns, tag);

  function nodePos(i: number): { x: number; y: number } {
    const level = Math.floor(Math.log2(i));
    const posInLevel = i - Math.pow(2, level);
    const totalAtLevel = Math.pow(2, level);
    const spacing = SVG_W / totalAtLevel;
    return {
      x: spacing * posInLevel + spacing / 2,
      y: TOP_PAD + level * LEVEL_H,
    };
  }

  /* ─── Render ─── */
  function render(highlights: Record<number, 'active' | 'swap' | 'settled'> = {}) {
    const n = heap.length - 1;

    edgesG.innerHTML = '';
    nodesG.innerHTML = '';
    emptyMsg.style.display = n === 0 ? 'block' : 'none';

    // Edges
    for (let i = 2; i <= n; i++) {
      const par = Math.floor(i / 2);
      const p1 = nodePos(par);
      const p2 = nodePos(i);
      const line = svgEl('line');
      line.setAttribute('x1', String(p1.x));
      line.setAttribute('y1', String(p1.y));
      line.setAttribute('x2', String(p2.x));
      line.setAttribute('y2', String(p2.y));
      line.setAttribute('stroke', COL.border);
      line.setAttribute('stroke-width', '1.5');
      edgesG.appendChild(line);
    }

    // Nodes
    for (let i = 1; i <= n; i++) {
      const { x, y } = nodePos(i);
      const h = highlights[i];

      const fill   = h === 'active'  ? 'rgba(126,255,245,0.13)'
                   : h === 'swap'    ? 'rgba(255,58,92,0.14)'
                   : h === 'settled' ? 'rgba(74,222,128,0.11)'
                   : COL.surface;
      const stroke = h === 'active'  ? COL.accent
                   : h === 'swap'    ? COL.red
                   : h === 'settled' ? COL.green
                   : COL.border;
      const textCol = h ? stroke : COL.text;

      const g = svgEl('g') as SVGGElement;
      if (h === 'active' || h === 'swap') {
        g.setAttribute('filter', 'url(#hv-glow)');
      }

      const circle = svgEl('circle');
      circle.setAttribute('cx', String(x));
      circle.setAttribute('cy', String(y));
      circle.setAttribute('r', String(NODE_R));
      circle.setAttribute('fill', fill);
      circle.setAttribute('stroke', stroke);
      circle.setAttribute('stroke-width', '1.5');

      const label = svgEl('text') as SVGTextElement;
      label.setAttribute('x', String(x));
      label.setAttribute('y', String(y + 1));
      label.setAttribute('text-anchor', 'middle');
      label.setAttribute('dominant-baseline', 'middle');
      label.setAttribute('fill', textCol);
      label.setAttribute('font-size', '12');
      label.setAttribute('font-family', 'IBM Plex Mono, monospace');
      label.setAttribute('font-weight', '600');
      label.textContent = String(heap[i]);

      const idx = svgEl('text') as SVGTextElement;
      idx.setAttribute('x', String(x));
      idx.setAttribute('y', String(y + NODE_R + 10));
      idx.setAttribute('text-anchor', 'middle');
      idx.setAttribute('dominant-baseline', 'middle');
      idx.setAttribute('fill', COL.muted);
      idx.setAttribute('font-size', '8.5');
      idx.setAttribute('font-family', 'IBM Plex Mono, monospace');
      idx.textContent = `[${i}]`;

      g.appendChild(circle);
      g.appendChild(label);
      g.appendChild(idx);
      nodesG.appendChild(g);
    }

    // Array: index row + cell row
    // Keep the static dummy elements, rebuild the rest
    arrIndices.innerHTML = '<span class="hv-arr-idx hv-arr-idx--dummy">0</span>';
    arrCells.innerHTML   = '<div class="hv-arr-cell hv-arr-cell--dummy">_</div>';

    for (let i = 1; i <= n; i++) {
      const h = highlights[i];
      const hClass = h ? `hv-arr-idx--${h}` : '';

      // Index label
      const idx = document.createElement('span');
      idx.className = `hv-arr-idx${hClass ? ' ' + hClass : ''}`;
      idx.textContent = String(i);
      arrIndices.appendChild(idx);

      // Cell
      const cell = document.createElement('div');
      cell.className = `hv-arr-cell${h ? ' hv-arr-cell--' + h : ''}`;
      cell.textContent = String(heap[i]);
      arrCells.appendChild(cell);
    }
  }

  /* ─── Log ─── */
  function log(text: string, type: 'normal' | 'active' | 'warn' = 'normal') {
    logMsg.textContent = text;
    logMsg.className = type === 'active' ? 'hv-log--active'
                     : type === 'warn'   ? 'hv-log--warn'
                     : '';
  }

  /* ─── Buttons ─── */
  function setButtons(disabled: boolean) {
    insertBtn.disabled = disabled;
    extractBtn.disabled = disabled;
    fillBtn.disabled = disabled;
    resetBtn.disabled = disabled;
  }

  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  /* ─── Step runner ─── */
  interface Step {
    heap: number[];
    hi: Record<number, 'active' | 'swap' | 'settled'>;
    msg: string;
    type?: 'normal' | 'active' | 'warn';
  }

  async function runSteps(steps: Step[]) {
    animating = true;
    setButtons(true);
    for (const s of steps) {
      heap = s.heap;
      render(s.hi);
      log(s.msg, s.type ?? 'active');
      await sleep(STEP_MS);
    }
    render({});
    animating = false;
    setButtons(false);
  }

  /* ─── Insert ─── */
  function buildInsertSteps(val: number): Step[] {
    const steps: Step[] = [];
    const h = [...heap];
    h.push(val);
    const newIdx = h.length - 1;

    steps.push({ heap: [...h], hi: { [newIdx]: 'active' },
      msg: `Appending ${val} at index [${newIdx}] — end of array` });

    let i = newIdx;
    while (i > 1) {
      const par = Math.floor(i / 2);
      steps.push({ heap: [...h], hi: { [i]: 'active', [par]: 'active' },
        msg: `Compare heap[${i}]=${h[i]} with parent heap[${par}]=${h[par]}` });

      if (h[i] > h[par]) {
        [h[i], h[par]] = [h[par], h[i]];
        steps.push({ heap: [...h], hi: { [i]: 'swap', [par]: 'swap' },
          msg: `${h[par]} > ${h[i]}  →  swap ↑  (bubble up)` });
        i = par;
      } else {
        steps.push({ heap: [...h], hi: { [i]: 'settled' },
          msg: `${h[i]} ≤ parent ${h[par]}  →  heap property satisfied ✓` });
        return steps;
      }
    }

    // reached root
    steps.push({ heap: [...h], hi: { [1]: 'settled' },
      msg: `${h[1]} reached root  →  done. Heap size: ${h.length - 1}` });
    return steps;
  }

  /* ─── Extract Max ─── */
  function buildExtractSteps(): Step[] {
    const steps: Step[] = [];
    const h = [...heap];
    const n = h.length - 1;
    const maxVal = h[1];

    steps.push({ heap: [...h], hi: { [1]: 'active' },
      msg: `Root is the maximum: ${maxVal}` });

    h[1] = h[n];
    h.pop();
    const newN = h.length - 1;

    if (newN === 0) {
      steps.push({ heap: [...h], hi: {},
        msg: `Heap is now empty after removing ${maxVal}.`, type: 'warn' });
      return steps;
    }

    steps.push({ heap: [...h], hi: { [1]: 'swap' },
      msg: `Move last element (${h[1]}) to root  →  bubble down` });

    let i = 1;
    while (true) {
      const l = 2 * i, r = 2 * i + 1;
      let largest = i;
      if (l <= newN && h[l] > h[largest]) largest = l;
      if (r <= newN && h[r] > h[largest]) largest = r;

      if (largest === i) {
        steps.push({ heap: [...h], hi: { [i]: 'settled' },
          msg: `${h[i]} ≥ both children  →  heap property restored ✓  (extracted: ${maxVal})` });
        break;
      }

      const hi: Record<number, 'active'> = { [i]: 'active' };
      if (l <= newN) hi[l] = 'active';
      if (r <= newN) hi[r] = 'active';
      steps.push({ heap: [...h], hi,
        msg: `Compare [${i}]=${h[i]} with children → larger child is [${largest}]=${h[largest]}` });

      [h[i], h[largest]] = [h[largest], h[i]];
      steps.push({ heap: [...h], hi: { [i]: 'swap', [largest]: 'swap' },
        msg: `Swap ${h[largest]} ↔ ${h[i]}  (bubble down)` });

      i = largest;
    }

    return steps;
  }

  /* ─── Event handlers ─── */
  insertBtn.addEventListener('click', () => {
    if (animating) return;
    const val = parseInt(valInput.value);
    if (isNaN(val) || val < 1 || val > 99) {
      log('Enter a number between 1 and 99.', 'warn');
      return;
    }
    if (heap.length - 1 >= MAX_NODES) {
      log(`Max ${MAX_NODES} nodes for this visualization.`, 'warn');
      return;
    }
    valInput.value = '';
    valInput.focus();
    runSteps(buildInsertSteps(val)).then(() => {
      log(`Inserted ${val}. Heap size: ${heap.length - 1}.`);
    });
  });

  valInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') insertBtn.click();
  });

  extractBtn.addEventListener('click', () => {
    if (animating) return;
    if (heap.length <= 1) { log('Heap is empty.', 'warn'); return; }
    const maxVal = heap[1];
    runSteps(buildExtractSteps()).then(() => {
      log(`Extracted max: ${maxVal}. New root: ${heap[1] ?? 'none'}.`);
    });
  });

  fillBtn.addEventListener('click', async () => {
    if (animating) return;
    heap = [0];
    render({});
    const vals = [42, 15, 67, 8, 33, 91, 20];
    setButtons(true);
    animating = true;
    for (const v of vals) {
      if (heap.length - 1 >= MAX_NODES) break;
      const steps = buildInsertSteps(v);
      for (const s of steps) {
        heap = s.heap;
        render(s.hi);
        log(s.msg, 'active');
        await sleep(STEP_MS * 0.55);
      }
      render({});
      await sleep(180);
    }
    log(`Quick fill complete. Heap has ${heap.length - 1} nodes. Try Extract Max!`);
    animating = false;
    setButtons(false);
  });

  resetBtn.addEventListener('click', () => {
    if (animating) return;
    heap = [0];
    render({});
    log('Heap cleared.', 'warn');
  });

  /* ─── Initial render ─── */
  render({});
})();
</script>
