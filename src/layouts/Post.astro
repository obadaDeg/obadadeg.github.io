---
import Base from './Base.astro';
import CertificateBadge from '@components/CertificateBadge.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  backLabel?: string;
  backHref?: string;
  relatedCertificates?: { collection: 'certificates', slug: string }[];
}

const {
  title,
  description,
  headings = [],
  backLabel = '← Back',
  backHref = '/',
  relatedCertificates = [],
} = Astro.props;

const tocHeadings = headings.filter(h => h.depth === 2);
---

<Base title={title} description={description}>
  <div id="read-progress" aria-hidden="true"></div>
  <main class="post-main">
    <div class="post-layout">
      <!-- Main content -->
      <article class="post-content">
        <a href={backHref} class="back-link">{backLabel}</a>
        {relatedCertificates.length > 0 && (
          <div class="post-badges">
            {relatedCertificates.map(cert => (
              <CertificateBadge certReference={cert} />
            ))}
          </div>
        )}
        <slot />
      </article>

      <!-- Table of Contents (only if headings exist) -->
      {tocHeadings.length > 0 && (
        <aside class="toc">
          <p class="toc-title">On this page</p>
          <nav>
            <ul>
              {tocHeadings.map(h => (
                <li>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </main>
</Base>

<style>
  .post-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .post-layout {
      grid-template-columns: 768px 1fr;
    }
  }

  .post-content {
    max-width: 768px;
    width: 100%;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    font-size: 0.875rem;
    margin-bottom: 2rem;
    transition: color 0.15s ease;
    animation: fade-in 0.35s ease-out 0.1s both;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: -1.5rem;
    margin-bottom: 2rem;
    animation: fade-in 0.35s ease-out 0.15s both;
  }

  .post-content {
    animation: fade-in 0.45s ease-out 0.2s both;
  }

  /* Table of Contents */
  .toc {
    position: sticky;
    top: 80px;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.8rem;
  }

  .toc-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .toc nav ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .toc nav a {
    color: var(--color-muted);
    transition: color 0.15s ease;
    line-height: 1.4;
  }

  .toc nav a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 1023px) {
    .toc {
      display: none;
    }
  }

  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--color-accent);
    z-index: 9999;
    transition: width 0.08s linear;
    pointer-events: none;
  }
</style>

<script>
  function initReadProgress() {
    const bar = document.getElementById('read-progress');
    if (!bar) return;
    const update = () => {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = total > 0 ? `${Math.min((scrolled / total) * 100, 100)}%` : '0%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
  document.addEventListener('astro:page-load', initReadProgress);
</script>
