---
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Personal portfolio and content hub for Obada Daghlas — Software Engineer & Security Researcher.',
} = Astro.props;

const fullTitle = title === 'Obada Daghlas' ? title : `${title} — Obada Daghlas`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Obada Daghlas" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ViewTransitions />
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
