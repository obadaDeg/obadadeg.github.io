---
import Page from '@layouts/Page.astro';
import { getCollection, getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allSeries = await getCollection('series', s => !s.data.draft);

const seriesWithCounts = await Promise.all(
  allSeries.map(async (s) => {
    let publishedCount = 0;
    for (const item of s.data.items) {
      try {
        const entry = await getEntry(item.collection, item.slug);
        if (entry && !entry.data.draft) publishedCount++;
      } catch { /* skip */ }
    }
    return { series: s, publishedCount };
  })
);

const visibleSeries = seriesWithCounts
  .filter(({ publishedCount }) => publishedCount > 0)
  .sort((a, b) => b.publishedCount - a.publishedCount);
---

<Page
  title="Series"
  description="Curated reading paths and content playlists by Obada Daghlas."
>
  <div class="ph">
    <span class="ph-eyebrow">SYS::SERIES</span>
    <h1 class="ph-title">Series</h1>
    <p class="ph-sub">Curated paths through related posts, writeups, and projects — read as a journey.</p>
    {visibleSeries.length > 0 && (
      <span class="ph-stat">{visibleSeries.length} active {visibleSeries.length === 1 ? 'series' : 'series'}</span>
    )}
  </div>

  {visibleSeries.length > 0 ? (
    <div class="series-list animate-on-scroll">
      {visibleSeries.map(({ series: s, publishedCount }) => (
        <a href={`${base}series/${s.slug}`} class="series-card">
          <div class="sc-left">
            <span class="sc-count">{publishedCount} {publishedCount === 1 ? 'part' : 'parts'}</span>
            <h2 class="sc-title">{s.data.title}</h2>
            <p class="sc-desc">{s.data.description}</p>
          </div>
          <span class="sc-arrow">→</span>
        </a>
      ))}
    </div>
  ) : (
    <p class="empty-msg">No series yet — check back soon.</p>
  )}
</Page>

<style>
  .series-list {
    display: flex;
    flex-direction: column;
  }

  .series-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: padding-left 0.2s ease;
  }

  .series-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .series-card:hover {
    padding-left: 0.5rem;
  }

  .sc-left {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    flex: 1;
  }

  .sc-count {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .sc-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    transition: color 0.15s ease;
    margin: 0;
    line-height: 1.3;
  }

  .series-card:hover .sc-title {
    color: var(--color-accent);
  }

  .sc-desc {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.55;
    margin: 0;
  }

  .sc-arrow {
    font-size: 1rem;
    color: var(--color-accent);
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    flex-shrink: 0;
  }

  .series-card:hover .sc-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .empty-msg {
    color: var(--color-muted);
    font-style: italic;
    font-size: 0.875rem;
  }

  @media (max-width: 600px) {
    .sc-arrow { opacity: 1; }
  }
</style>
