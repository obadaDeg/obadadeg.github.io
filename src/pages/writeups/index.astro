---
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allWriteups = await getCollection('writeups');
const writeups = allWriteups
  .filter(w => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = ['Web', 'Pwn', 'Crypto', 'Forensics', 'Misc', 'OSINT'];

const diffColor: Record<string, string> = {
  Easy:   '#4ade80',
  Medium: '#facc15',
  Hard:   '#f87171',
};
---

<Page title="CTF Writeups" description="CTF challenge writeups by Obada Daghlas — web, pwn, crypto, and more.">
  <div class="ph">
    <span class="ph-eyebrow">SYS::WRITEUPS</span>
    <h1 class="ph-title">CTF Writeups</h1>
    <p class="ph-sub">Technical writeups from CTF competitions and security challenges.</p>
    {writeups.length > 0 && (
      <span class="ph-stat">{writeups.length} {writeups.length === 1 ? 'writeup' : 'writeups'}</span>
    )}
  </div>

  <!-- Category filter -->
  <div class="cat-filter animate-on-scroll">
    <a href={`${base}writeups`} class="cat-pill cat-pill--all">All</a>
    {categories.map(cat => (
      <a
        href={`${base}writeups/category/${cat.toLowerCase()}`}
        class="cat-pill"
      >{cat}</a>
    ))}
  </div>

  {writeups.length > 0 ? (
    <ul class="el animate-on-scroll">
      {writeups.map(w => (
        <li class="el-row">
          <div class="wu-main">
            <a href={`${base}writeups/${w.slug}`} class="el-title">{w.data.title}</a>
            <span class="wu-ctf">{w.data.ctf}</span>
          </div>
          <span class="el-tags">
            <span class="el-cat">{w.data.category}</span>
            <span
              class="wu-diff"
              style={`color: ${diffColor[w.data.difficulty] ?? 'var(--color-muted)'}`}
            >{w.data.difficulty}</span>
          </span>
          <time class="el-date">
            {w.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty-msg">No writeups yet — check back soon.</p>
  )}
</Page>

<style>
  /* Category filter */
  .cat-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 2.5rem;
  }

  .cat-pill {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-muted);
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
    letter-spacing: 0.04em;
  }

  .cat-pill:hover,
  .cat-pill--all {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  /* Writeup row extras */
  .wu-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .wu-ctf {
    font-size: 0.65rem;
    color: var(--color-muted);
    font-family: 'IBM Plex Mono', monospace;
  }

  .wu-diff {
    font-size: 0.65rem;
    font-family: 'IBM Plex Mono', monospace;
    white-space: nowrap;
  }

  .el-row { align-items: start; }
  .el-title { white-space: normal; font-family: 'Syne', sans-serif; font-weight: 600; }

  .empty-msg {
    color: var(--color-muted);
    font-style: italic;
    font-size: 0.875rem;
  }

  @media (max-width: 600px) {
    .el-row { grid-template-columns: 1fr; }
    .el-tags, .el-date { order: 2; }
  }
</style>
