---
import Post from '@layouts/Post.astro';
import TagPill from '@components/TagPill.astro';
import CopyButton from '@components/CopyButton.astro';
import SeriesNavigator from '@components/SeriesNavigator.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

type SeriesNavItem = { title: string; href: string };
type SeriesContext = {
  seriesTitle: string;
  seriesSlug: string;
  currentIndex: number;
  total: number;
  prevItem?: SeriesNavItem;
  nextItem?: SeriesNavItem;
} | null;

type Props = { writeup: CollectionEntry<'writeups'>; seriesContext: SeriesContext };

export async function getStaticPaths() {
  const allWriteups = await getCollection('writeups');
  const writeups = allWriteups.filter(w => !w.data.draft);
  const allSeries = await getCollection('series', s => !s.data.draft);

  return await Promise.all(
    writeups.map(async (w: CollectionEntry<'writeups'>) => {
      let seriesContext: SeriesContext = null;

      const matchedSeries = allSeries.find(s =>
        s.data.items.some(i => i.collection === 'writeups' && i.slug === w.slug)
      );

      if (matchedSeries) {
        const publishedItems: { title: string; href: string; slug: string }[] = [];
        for (const item of matchedSeries.data.items) {
          try {
            const entry = await getEntry(item.collection, item.slug);
            if (entry && !entry.data.draft) {
              const href = `${base}${item.collection === 'writeups' ? 'writeups' : item.collection === 'projects' ? 'projects' : 'blog'}/${item.slug}`;
              publishedItems.push({ title: entry.data.title, href, slug: item.slug });
            }
          } catch { /* skip missing */ }
        }

        const currentIndex = publishedItems.findIndex(i => i.slug === w.slug);
        if (currentIndex !== -1) {
          seriesContext = {
            seriesTitle: matchedSeries.data.title,
            seriesSlug: matchedSeries.slug,
            currentIndex,
            total: publishedItems.length,
            prevItem: currentIndex > 0 ? publishedItems[currentIndex - 1] : undefined,
            nextItem: currentIndex < publishedItems.length - 1 ? publishedItems[currentIndex + 1] : undefined,
          };
        }
      }

      return {
        params: { slug: w.slug },
        props: { writeup: w, seriesContext },
      };
    })
  );
}

const { writeup, seriesContext } = Astro.props;
const { Content, headings } = await writeup.render();

const formattedDate = writeup.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const difficultyColor: Record<string, string> = {
  Easy: '#4ade80',
  Medium: '#facc15',
  Hard: '#f87171',
};
---

<Post
  title={writeup.data.title}
  description={writeup.data.excerpt}
  headings={headings}
  backLabel="← All Writeups"
  backHref={`${base}writeups`}
>
  <!-- Metadata header -->
  <div class="meta-header">
    <h1 class="writeup-title">{writeup.data.title}</h1>
    <div class="meta-row">
      <span class="meta-ctf">{writeup.data.ctf}</span>
      <TagPill
        label={writeup.data.category}
        href={`${base}writeups/category/${writeup.data.category.toLowerCase()}`}
      />
      <span
        class="meta-difficulty"
        style={`color: ${difficultyColor[writeup.data.difficulty] ?? 'var(--color-muted)'}`}
      >
        {writeup.data.difficulty}
      </span>
      <span class="meta-date">{formattedDate}</span>
    </div>
    {writeup.data.tags.length > 0 && (
      <div class="meta-tags">
        {writeup.data.tags.map(tag => <TagPill label={tag} />)}
      </div>
    )}
    <p class="meta-excerpt">{writeup.data.excerpt}</p>
  </div>

  <!-- Prose content -->
  <div class="prose">
    <Content />
  </div>

  <!-- Series Navigator -->
  {seriesContext && (
    <SeriesNavigator
      seriesTitle={seriesContext.seriesTitle}
      seriesSlug={seriesContext.seriesSlug}
      currentIndex={seriesContext.currentIndex}
      total={seriesContext.total}
      prevItem={seriesContext.prevItem}
      nextItem={seriesContext.nextItem}
    />
  )}

  <!-- Copy button island -->
  <CopyButton />
</Post>

<style>
  .meta-header {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .writeup-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .meta-ctf {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .meta-difficulty {
    font-size: 0.8rem;
    font-family: 'IBM Plex Mono', monospace;
  }

  .meta-date {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .meta-excerpt {
    font-size: 0.875rem;
    color: var(--color-muted);
    border-left: 2px solid var(--color-accent);
    padding-left: 0.75rem;
    margin-top: 0.5rem;
    line-height: 1.6;
  }
</style>
