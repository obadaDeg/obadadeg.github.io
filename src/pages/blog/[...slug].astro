---
import Post from '@layouts/Post.astro';
import TagPill from '@components/TagPill.astro';
import CopyButton from '@components/CopyButton.astro';
import SeriesNavigator from '@components/SeriesNavigator.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

type SeriesNavItem = { title: string; href: string };
type SeriesContext = {
  seriesTitle: string;
  seriesSlug: string;
  currentIndex: number;
  total: number;
  prevItem?: SeriesNavItem;
  nextItem?: SeriesNavItem;
} | null;

type Props = { post: CollectionEntry<'blog'>; seriesContext: SeriesContext };

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const allSeries = await getCollection('series', s => !s.data.draft);

  return await Promise.all(
    posts.map(async (post: CollectionEntry<'blog'>) => {
      let seriesContext: SeriesContext = null;

      // Find the series this post belongs to
      const matchedSeries = allSeries.find(s =>
        s.data.items.some(i => i.collection === 'blog' && i.slug === post.slug)
      );

      if (matchedSeries) {
        // Resolve published items from the series
        const publishedItems: { title: string; href: string; slug: string }[] = [];
        for (const item of matchedSeries.data.items) {
          try {
            const entry = await getEntry(item.collection, item.slug);
            if (entry && !entry.data.draft) {
              const href = `${base}${item.collection === 'writeups' ? 'writeups' : item.collection === 'projects' ? 'projects' : 'blog'}/${item.slug}`;
              publishedItems.push({ title: entry.data.title, href, slug: item.slug });
            }
          } catch { /* skip missing */ }
        }

        const currentIndex = publishedItems.findIndex(i => i.slug === post.slug);
        if (currentIndex !== -1) {
          seriesContext = {
            seriesTitle: matchedSeries.data.title,
            seriesSlug: matchedSeries.slug,
            currentIndex,
            total: publishedItems.length,
            prevItem: currentIndex > 0 ? publishedItems[currentIndex - 1] : undefined,
            nextItem: currentIndex < publishedItems.length - 1 ? publishedItems[currentIndex + 1] : undefined,
          };
        }
      }

      return {
        params: { slug: post.slug },
        props: { post, seriesContext },
      };
    })
  );
}

const { post, seriesContext } = Astro.props;
const { Content, headings } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Post
  title={post.data.title}
  description={post.data.excerpt}
  headings={headings}
  backLabel="← All Posts"
  backHref={`${base}blog`}
>
  <!-- Post header -->
  <div class="post-header">
    <h1 class="post-title">{post.data.title}</h1>
    <div class="post-meta">
      <span class="post-date">{formattedDate}</span>
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag: string) => <TagPill label={tag} />)}
        </div>
      )}
    </div>
  </div>

  <!-- Prose content -->
  <div class="prose">
    <Content />
  </div>

  <!-- Series Navigator -->
  {seriesContext && (
    <SeriesNavigator
      seriesTitle={seriesContext.seriesTitle}
      seriesSlug={seriesContext.seriesSlug}
      currentIndex={seriesContext.currentIndex}
      total={seriesContext.total}
      prevItem={seriesContext.prevItem}
      nextItem={seriesContext.nextItem}
    />
  )}

  <!-- Copy button island -->
  <CopyButton />
</Post>

<style>
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
