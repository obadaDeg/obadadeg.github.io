---
import Post from '@layouts/Post.astro';
import SeriesNavigator from '@components/SeriesNavigator.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

type SeriesNavItem = { title: string; href: string };
type SeriesContext = {
  seriesTitle: string;
  seriesSlug: string;
  currentIndex: number;
  total: number;
  prevItem?: SeriesNavItem;
  nextItem?: SeriesNavItem;
} | null;

type Props = { project: CollectionEntry<'projects'>; seriesContext: SeriesContext };

export async function getStaticPaths() {
  const projects = await getCollection('projects', p => !p.data.draft);
  const allSeries = await getCollection('series', s => !s.data.draft);

  return await Promise.all(
    projects.map(async (project: CollectionEntry<'projects'>) => {
      let seriesContext: SeriesContext = null;

      const matchedSeries = allSeries.find(s =>
        s.data.items.some(i => i.collection === 'projects' && i.slug === project.slug)
      );

      if (matchedSeries) {
        const publishedItems: { title: string; href: string; slug: string }[] = [];
        for (const item of matchedSeries.data.items) {
          try {
            const entry = await getEntry(item.collection, item.slug);
            if (entry && !entry.data.draft) {
              const href = `${base}${item.collection === 'writeups' ? 'writeups' : item.collection === 'projects' ? 'projects' : 'blog'}/${item.slug}`;
              publishedItems.push({ title: entry.data.title, href, slug: item.slug });
            }
          } catch { /* skip missing */ }
        }

        const currentIndex = publishedItems.findIndex(i => i.slug === project.slug);
        if (currentIndex !== -1) {
          seriesContext = {
            seriesTitle: matchedSeries.data.title,
            seriesSlug: matchedSeries.slug,
            currentIndex,
            total: publishedItems.length,
            prevItem: currentIndex > 0 ? publishedItems[currentIndex - 1] : undefined,
            nextItem: currentIndex < publishedItems.length - 1 ? publishedItems[currentIndex + 1] : undefined,
          };
        }
      }

      return {
        params: { slug: project.slug },
        props: { project, seriesContext },
      };
    })
  );
}

const { project, seriesContext } = Astro.props;
const { Content, headings } = await project.render();

const formattedDate = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Post
  title={project.data.title}
  description={project.data.description}
  headings={headings}
  backLabel="← All Projects"
  backHref={`${base}projects`}
  relatedCertificates={project.data.relatedCertificates}
>
  <!-- Project header -->
  <div class="project-header">
    <h1 class="project-title">{project.data.title}</h1>
    <p class="project-desc">{project.data.description}</p>

    <!-- Tech stack -->
    <div class="project-tech">
      {project.data.tech.map((t: string) => (
        <span class="tech-pill">{t}</span>
      ))}
    </div>

    <!-- Links -->
    <div class="project-links">
      <a
        href={project.data.github}
        target="_blank"
        rel="noopener noreferrer"
        class="project-link project-link-github"
      >
        GitHub ↗
      </a>
      {project.data.demo && (
        <a
          href={project.data.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="project-link project-link-demo"
        >
          Live Demo ↗
        </a>
      )}
    </div>

    <span class="project-date">{formattedDate}</span>
  </div>

  <!-- Case study / prose body (optional) -->
  <div class="prose">
    <Content />
  </div>

  <!-- Series Navigator -->
  {seriesContext && (
    <SeriesNavigator
      seriesTitle={seriesContext.seriesTitle}
      seriesSlug={seriesContext.seriesSlug}
      currentIndex={seriesContext.currentIndex}
      total={seriesContext.total}
      prevItem={seriesContext.prevItem}
      nextItem={seriesContext.nextItem}
    />
  )}
</Post>

<style>
  .project-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .project-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .project-desc {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .tech-pill {
    font-size: 0.72rem;
    padding: 0.18rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text);
    font-family: 'IBM Plex Mono', monospace;
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .project-link {
    font-size: 0.82rem;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    transition: background 0.15s ease, color 0.15s ease;
    text-decoration: none;
  }

  .project-link-github {
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
  }

  .project-link-github:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .project-link-demo {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .project-link-demo:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .project-date {
    font-size: 0.72rem;
    color: var(--color-muted);
    font-family: 'IBM Plex Mono', monospace;
  }
</style>
