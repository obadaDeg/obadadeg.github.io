---
import Page from '@layouts/Page.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allProjects = await getCollection('projects', p => !p.data.draft);
const projects = allProjects.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

const featuredCount = projects.filter(p => p.data.featured).length;
---

<Page title="Projects" description="A selection of things built by Obada Daghlas — backend services, APIs, and tools.">
  <div class="ph">
    <span class="ph-eyebrow">SYS::PROJECTS</span>
    <h1 class="ph-title">Projects</h1>
    <p class="ph-sub">Backend services, APIs, security tools, and full-stack applications.</p>
    {projects.length > 0 && (
      <span class="ph-stat">
        {projects.length} {projects.length === 1 ? 'project' : 'projects'}
        {featuredCount > 0 && ` · ${featuredCount} featured`}
      </span>
    )}
  </div>

  {projects.length > 0 ? (
    <div class="proj-grid animate-on-scroll">
      {projects.map(project => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tech={project.data.tech}
          github={project.data.github}
          demo={project.data.demo}
          featured={project.data.featured}
          href={`${base}projects/${project.slug}`}
        />
      ))}
    </div>
  ) : (
    <p class="empty-msg">No projects yet — check back soon.</p>
  )}
</Page>

<style>
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .proj-grid { grid-template-columns: 1fr; }
  }

  .empty-msg {
    color: var(--color-muted);
    font-style: italic;
    font-size: 0.875rem;
  }
</style>
