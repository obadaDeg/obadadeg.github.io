---
import Page from '@layouts/Page.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allWriteups = await getCollection('writeups');
const recentWriteups = allWriteups
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<Page
  title="Obada Daghlas"
  description="Personal portfolio and content hub for Obada Daghlas — Software Engineer & Security Researcher."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-left">
      <h1 class="hero-name">Obada Daghlas</h1>
      <div class="terminal-block">
        <pre><code><span class="prompt">&gt;</span> whoami
obada@daghlas ~ software engineer, security researcher
<span class="prompt">&gt;</span> cat interests.txt
fullstack development, penetration testing, CTFs, cloud infra</code></pre>
      </div>
    </div>

    <div class="hero-right">
      <p class="hero-title">Software Engineer · Security Researcher</p>
      <p class="hero-bio">
        I build things and break them. Software engineering intern by day, CTF player
        and security researcher by night. Interested in full-stack development,
        cloud infrastructure, and web application security.
      </p>
      <a
        href="https://github.com/obadaDeg"
        target="_blank"
        rel="noopener noreferrer"
        class="github-cta"
      >
        ↗ View GitHub
      </a>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="home-section section-separator">
      <div class="section-header">
        <h2 class="section-title">Featured Projects</h2>
        <a href="/projects" class="section-link">All projects →</a>
      </div>
      <div class="projects-grid">
        {featuredProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            github={project.data.github}
            demo={project.data.demo}
            featured={project.data.featured}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Writeups -->
  <section class="home-section section-separator">
    <div class="section-header">
      <h2 class="section-title">Recent Writeups</h2>
      <a href="/writeups" class="section-link">All writeups →</a>
    </div>
    {recentWriteups.length > 0 ? (
      <ul class="writeup-list">
        {recentWriteups.map(w => (
          <li class="writeup-item">
            <a href={`/writeups/${w.slug}`} class="writeup-title">{w.data.title}</a>
            <span class="writeup-meta">
              <span class="writeup-ctf">{w.data.ctf}</span>
              <span class="writeup-cat">{w.data.category}</span>
              <span class="writeup-date">
                {w.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Writeups coming soon.</p>
    )}
  </section>

  <!-- Recent Blog Posts -->
  <section class="home-section section-separator">
    <div class="section-header">
      <h2 class="section-title">From the Blog</h2>
      <a href="/blog" class="section-link">All posts →</a>
    </div>
    {recentPosts.length > 0 ? (
      <ul class="writeup-list">
        {recentPosts.map(post => (
          <li class="writeup-item">
            <a href={`/blog/${post.slug}`} class="writeup-title">{post.data.title}</a>
            <span class="writeup-meta">
              <span class="writeup-date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Posts coming soon.</p>
    )}
  </section>
</Page>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .hero-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .terminal-block pre {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    overflow-x: auto;
  }

  .terminal-block code {
    font-family: 'IBM Plex Mono', monospace;
  }

  .prompt {
    color: var(--color-accent);
  }

  .hero-right {
    padding-top: 0.5rem;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-bio {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .github-cta {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 6px;
    font-size: 0.875rem;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .github-cta:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* Sections */
  .home-section {
    padding-top: 3.5rem;
    margin-bottom: 1rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }

  .section-title {
    font-size: 1.4rem;
    font-family: 'Syne', sans-serif;
  }

  .section-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .section-link:hover {
    color: var(--color-accent);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* Writeup / post list */
  .writeup-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .writeup-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .writeup-title {
    font-size: 0.9rem;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .writeup-title:hover {
    color: var(--color-accent);
  }

  .writeup-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .writeup-ctf,
  .writeup-date {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .writeup-cat {
    font-size: 0.7rem;
    padding: 0.1rem 0.45rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    white-space: nowrap;
  }

  .empty-state {
    color: var(--color-muted);
    font-size: 0.875rem;
    font-style: italic;
  }
</style>
