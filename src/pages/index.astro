---
import Page from '@layouts/Page.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allProjects: CollectionEntry<'projects'>[] = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allWriteups: CollectionEntry<'writeups'>[] = await getCollection('writeups');
const recentWriteups = allWriteups
  .filter(w => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
const recentPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

// Recent Series — fetch published series with at least one published item
const allSeries = await getCollection('series', s => !s.data.draft);
const seriesWithCounts = await Promise.all(
  allSeries.map(async (s) => {
    let count = 0;
    for (const item of s.data.items) {
      try {
        const entry = await getEntry(item.collection, item.slug);
        if (entry && !entry.data.draft) count++;
      } catch { /* skip */ }
    }
    return { series: s, count };
  })
);
const recentSeries = seriesWithCounts
  .filter(({ count }) => count > 0)
  .slice(0, 2);
---

<Page
  title="Obada Daghlas"
  description="Personal portfolio and content hub for Obada Daghlas — Software Engineer & Security Researcher."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-left">
      <div class="avail-badge">
        <span class="avail-dot"></span>
        Open to opportunities
      </div>
      <h1 class="hero-name" data-text="Obada Daghlas">Obada Daghlas</h1>
      <div class="terminal-block hero-term">
        <pre><code id="terminal-code"><span class="prompt">&gt;</span> whoami
obada@daghlas ~ software engineer, security researcher
<span class="prompt">&gt;</span> cat interests.txt
fullstack development, penetration testing, CTFs, cloud infra<span class="term-cursor blink">█</span></code></pre>
      </div>
    </div>

    <div class="hero-right">
      <p class="hero-title hero-role">Software Engineer · Security Researcher</p>
      <p class="hero-bio">
        I build things and break them. Software engineering intern by day, CTF player
        and security researcher by night. Interested in full-stack development,
        cloud infrastructure, and web application security.
      </p>
      <a
        href="https://github.com/obadaDeg"
        target="_blank"
        rel="noopener noreferrer"
        class="github-cta hero-cta"
      >
        ↗ View GitHub
      </a>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="home-section section-separator animate-on-scroll">
      <div class="section-header">
        <h2 class="section-title">Featured Projects</h2>
        <a href={`${import.meta.env.BASE_URL}projects`} class="section-link">All projects →</a>
      </div>
      <div class="projects-grid">
        {featuredProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            github={project.data.github}
            demo={project.data.demo}
            featured={project.data.featured}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Writeups -->
  <section class="home-section section-separator animate-on-scroll">
    <div class="section-header">
      <h2 class="section-title">Recent Writeups</h2>
      <a href={`${import.meta.env.BASE_URL}writeups`} class="section-link">All writeups →</a>
    </div>
    {recentWriteups.length > 0 ? (
      <ul class="writeup-list">
        {recentWriteups.map(w => (
          <li class="writeup-item">
            <a href={`${import.meta.env.BASE_URL}writeups/${w.slug}`} class="writeup-title">{w.data.title}</a>
            <span class="writeup-meta">
              <span class="writeup-ctf">{w.data.ctf}</span>
              <span class="writeup-cat">{w.data.category}</span>
              <span class="writeup-date">
                {w.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Writeups coming soon.</p>
    )}
  </section>

  <!-- Stack -->
  <section class="home-section section-separator animate-on-scroll">
    <div class="section-header">
      <h2 class="section-title">Stack</h2>
    </div>
    <div class="stack-groups">
      {[
        { label: 'Languages', items: ['TypeScript', 'Go', 'Python', 'C', 'Bash'] },
        { label: 'Frontend',  items: ['Astro', 'React', 'Tailwind CSS'] },
        { label: 'Backend',   items: ['Node.js', 'Express', 'PostgreSQL', 'Redis', 'BullMQ', 'Drizzle ORM'] },
        { label: 'Security',  items: ['Burp Suite', 'Wireshark', 'nmap', 'OSINT', 'Metasploit'] },
        { label: 'DevOps',    items: ['Docker', 'GitHub Actions', 'Linux'] },
      ].map(group => (
        <div class="stack-group">
          <span class="stack-label">{group.label}</span>
          <div class="stack-pills">
            {group.items.map(item => <span class="stack-pill">{item}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Blog Posts -->
  <section class="home-section section-separator animate-on-scroll">
    <div class="section-header">
      <h2 class="section-title">From the Blog</h2>
      <a href={`${import.meta.env.BASE_URL}blog`} class="section-link">All posts →</a>
    </div>
    {recentPosts.length > 0 ? (
      <ul class="writeup-list">
        {recentPosts.map(post => (
          <li class="writeup-item">
            <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="writeup-title">{post.data.title}</a>
            <span class="writeup-meta">
              <span class="writeup-date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Posts coming soon.</p>
    )}
  </section>

  <!-- Recent Series -->
  {recentSeries.length > 0 && (
    <section class="home-section section-separator animate-on-scroll">
      <div class="section-header">
        <h2 class="section-title">Series</h2>
        <a href={`${base}series`} class="section-link">All series →</a>
      </div>
      <ul class="writeup-list">
        {recentSeries.map(({ series: s, count }) => (
          <li class="writeup-item">
            <a href={`${base}series/${s.slug}`} class="writeup-title">{s.data.title}</a>
            <span class="writeup-meta">
              <span class="writeup-ctf">{s.data.description}</span>
              <span class="writeup-cat">{count} {count === 1 ? 'part' : 'parts'}</span>
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Page>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    min-height: calc(100vh - 60px);
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Scanline overlay */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.018) 2px,
      rgba(0, 0, 0, 0.018) 4px
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      min-height: auto;
      padding-top: 3rem;
    }

    .terminal-block pre {
      font-size: 0.72rem;
    }
  }

  /* Glitch effect on hero name hover */
  .hero-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1.5rem;
    color: var(--color-text);
    position: relative;
    cursor: default;
    display: inline-block;
  }

  .hero-name::before,
  .hero-name::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }

  .hero-name:hover::before {
    color: #ff3366;
    opacity: 0.85;
    text-shadow: 2px 0 #ff3366;
    animation: glitch-clip-1 0.35s steps(1) infinite;
  }

  .hero-name:hover::after {
    color: var(--color-accent);
    opacity: 0.85;
    text-shadow: -2px 0 var(--color-accent);
    animation: glitch-clip-2 0.35s steps(1) infinite 0.12s;
  }

  .terminal-block pre {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    overflow-x: hidden;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .terminal-block code {
    font-family: 'IBM Plex Mono', monospace;
  }

  .avail-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
    padding: 0.28rem 0.75rem 0.28rem 0.55rem;
    border: 1px solid rgba(74, 222, 128, 0.25);
    border-radius: 999px;
    letter-spacing: 0.03em;
  }

  .avail-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  .prompt {
    color: var(--color-accent);
  }

  .hero-left,
  .hero-right {
    min-width: 0;
  }

  .hero-right {
    padding-top: 0.5rem;
  }

  .terminal-block {
    max-width: 100%;
    overflow: hidden;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-bio {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .github-cta {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 6px;
    font-size: 0.875rem;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    will-change: transform;
  }

  .github-cta:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    box-shadow: 0 0 20px rgba(126, 255, 245, 0.3);
  }

  /* Sections */
  .home-section {
    padding-top: 3.5rem;
    margin-bottom: 1rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }

  .section-title {
    font-size: 1.4rem;
    font-family: 'Syne', sans-serif;
  }

  .section-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .section-link:hover {
    color: var(--color-accent);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* Writeup / post list */
  .writeup-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .writeup-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .writeup-title {
    font-size: 0.9rem;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .writeup-title:hover {
    color: var(--color-accent);
  }

  .writeup-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .writeup-ctf,
  .writeup-date {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .writeup-cat {
    font-size: 0.7rem;
    padding: 0.1rem 0.45rem;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    white-space: nowrap;
  }

  .empty-state {
    color: var(--color-muted);
    font-size: 0.875rem;
    font-style: italic;
  }

  /* Stack section */
  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .stack-group {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .stack-label {
    font-size: 0.68rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    min-width: 88px;
    padding-top: 0.28rem;
    flex-shrink: 0;
  }

  .stack-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .stack-pill {
    font-size: 0.75rem;
    padding: 0.18rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text);
    transition: border-color 0.15s ease, color 0.15s ease;
    cursor: default;
  }

  .stack-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .stack-group {
      flex-direction: column;
      gap: 0.5rem;
    }
    .stack-label {
      min-width: unset;
    }
  }
</style>

<script>
  const SCRAMBLE_CHARS = '!<>-_\\/[]{}=+*^?#@$%01';

  function scramble(el: HTMLElement) {
    const final = el.dataset.text ?? el.textContent ?? '';
    const len = final.length;
    const totalFrames = 38;
    let frame = 0;

    const id = setInterval(() => {
      let out = '';
      const progress = frame / totalFrames;

      for (let i = 0; i < len; i++) {
        if (final[i] === ' ') { out += ' '; continue; }
        if (progress > i / len + 0.12) {
          out += final[i];
        } else {
          out += SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
        }
      }

      el.textContent = out;
      frame++;
      if (frame > totalFrames) { el.textContent = final; clearInterval(id); }
    }, 30);
  }

  async function initTerminalTyping() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const code = document.getElementById('terminal-code') as HTMLElement | null;
    if (!code) return;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
    const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    const sequence: Array<{ cmd: boolean; text: string }> = [
      { cmd: true,  text: 'whoami' },
      { cmd: false, text: 'obada@daghlas ~ software engineer, security researcher' },
      { cmd: true,  text: 'cat interests.txt' },
      { cmd: false, text: 'fullstack development, penetration testing, CTFs, cloud infra' },
    ];

    const cursor = () => '<span class="term-cursor">█</span>';

    let built = '';
    code.innerHTML = cursor();

    for (let i = 0; i < sequence.length; i++) {
      const item = sequence[i];
      if (i > 0) {
        built += '\n';
        await sleep(item.cmd ? 650 : 250);
      }
      const prefix = item.cmd ? '<span class="prompt">&gt;</span> ' : '';
      const delay  = item.cmd ? 65 : 22;
      let typed = '';
      for (const ch of item.text) {
        typed += ch;
        code.innerHTML = built + prefix + esc(typed) + cursor();
        await sleep(delay + Math.random() * 25);
      }
      built += prefix + esc(item.text);
    }

    code.innerHTML = built + '<span class="term-cursor blink">█</span>';
  }

  function initHeroEffects() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Scramble hero name on load
    const nameEl = document.querySelector<HTMLElement>('.hero-name');
    if (nameEl) {
      setTimeout(() => scramble(nameEl), 200);
    }

    // Magnetic CTA button (desktop only)
    if (!window.matchMedia('(pointer: fine)').matches) return;
    const btn = document.querySelector<HTMLElement>('.github-cta');
    if (!btn) return;

    btn.addEventListener('mousemove', (e) => {
      const r = btn.getBoundingClientRect();
      const x = ((e as MouseEvent).clientX - r.left - r.width  / 2) * 0.22;
      const y = ((e as MouseEvent).clientY - r.top  - r.height / 2) * 0.22;
      btn.style.transform = `translate(${x}px, ${y}px)`;
    });

    btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
  }

  document.addEventListener('astro:page-load', initHeroEffects);
  document.addEventListener('astro:page-load', initTerminalTyping);
</script>
