</style>

<script>
  /* ── Live clock (Damascus time) ── */
  function initLiveClock() {
    const el = document.getElementById('live-time');
    if (!el) return;
    const tick = () => {
      try {
        el.textContent = new Date().toLocaleTimeString('en-US', {
          hour12: false,
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          timeZone: 'Asia/Damascus',
        });
      } catch {
        el.textContent = new Date().toLocaleTimeString('en-US', {
          hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit',
        });
      }
    };
    tick();
    const id = setInterval(tick, 1000);
    document.addEventListener('astro:before-swap', () => clearInterval(id), { once: true });
  }

  /* ── Animated node-network canvas ── */
  function initCanvas() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    if (!ctx) return;
    const hero = canvas.parentElement!;

    let w = hero.offsetWidth;
    let h = hero.offsetHeight;
    canvas.width = w;
    canvas.height = h;

    const N = Math.min(60, Math.max(20, Math.floor((w * h) / 14000)));
    const nodes = Array.from({ length: N }, () => ({
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * 0.22,
      vy: (Math.random() - 0.5) * 0.22,
      r: Math.random() * 1.4 + 0.5,
    }));

    const MAX_DIST = 145;
    let raf: number;

    function draw() {
      ctx.clearRect(0, 0, w, h);

      // Move
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > w) n.vx *= -1;
        if (n.y < 0 || n.y > h) n.vy *= -1;
      }

      // Edges
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const d = Math.hypot(dx, dy);
          if (d < MAX_DIST) {
            const alpha = (1 - d / MAX_DIST) * 0.13;
            ctx.strokeStyle = `rgba(126,255,245,${alpha})`;
            ctx.lineWidth = 0.6;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
      }

      // Nodes
      for (const n of nodes) {
        ctx.fillStyle = 'rgba(126,255,245,0.38)';
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }

      raf = requestAnimationFrame(draw);
    }

    draw();

    const ro = new ResizeObserver(() => {
      w = hero.offsetWidth;
      h = hero.offsetHeight;
      canvas.width = w;
      canvas.height = h;
    });
    ro.observe(hero);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      ro.disconnect();
    }, { once: true });
  }

  /* ── Stats count-up ── */
  function initCounters() {
    const els = document.querySelectorAll<HTMLElement>('.hs-n');
    if (!els.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(el => { el.textContent = el.dataset.count ?? '0'; });
      return;
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.count ?? '0', 10);
        let current = 0;
        const duration = 900;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          current = Math.round(eased * target);
          el.textContent = current.toString();
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        obs.unobserve(el);
      });
    }, { threshold: 0.6 });

    els.forEach(el => obs.observe(el));
  }

  /* ── Terminal typing ── */
  async function initTerminal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const code = document.getElementById('terminal-code') as HTMLElement | null;
    if (!code) return;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
    const esc = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const cur = () => '<span class="term-cursor">█</span>';

    const seq = [
      { cmd: true,  text: 'whoami' },
      { cmd: false, text: 'obada@daghlas ~ cybersec + software engineer' },
      { cmd: true,  text: 'cat interests.txt' },
      { cmd: false, text: 'web app pentesting · CTFs · backend engineering · cloud infra' },
    ];

    let built = '';
    code.innerHTML = '<span class="prompt">$</span> ' + cur();
    await sleep(1100);

    for (let i = 0; i < seq.length; i++) {
      const item = seq[i];
      if (i > 0) {
        built += '\n';
        await sleep(item.cmd ? 720 : 300);
      }
      const prefix = item.cmd ? '<span class="prompt">$</span> ' : '  ';
      const delay  = item.cmd ? 60 : 18;
      let typed = '';
      for (const ch of item.text) {
        typed += ch;
        code.innerHTML = built + prefix + esc(typed) + cur();
        await sleep(delay + Math.random() * 20);
      }
      built += prefix + esc(item.text);
    }

    code.innerHTML = built + '<span class="term-cursor blink">█</span>';
  }

  /* ── Name scramble (after wipe animation settles) ── */
  function initScramble() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const CHARS = '!<>-_\\/[]{}=+*^?#@$%01';
    const nameEl = document.querySelector<HTMLElement>('.hero-name');
    if (!nameEl) return;
    const final = nameEl.dataset.text ?? '';
    const len = final.length;

    setTimeout(() => {
      let frame = 0;
      const FRAMES = 36;
      const id = setInterval(() => {
        const p = frame / FRAMES;
        let out = '';
        for (let i = 0; i < len; i++) {
          if (final[i] === ' ') { out += ' '; continue; }
          out += p > i / len + 0.12
            ? final[i]
            : CHARS[Math.floor(Math.random() * CHARS.length)];
        }
        nameEl.textContent = out;
        frame++;
        if (frame > FRAMES) { nameEl.textContent = final; clearInterval(id); }
      }, 28);
    }, 1300);
  }

  /* ── Magnetic hover on CTAs ── */
  function initMagnetic() {
    if (!window.matchMedia('(pointer: fine)').matches) return;
    document.querySelectorAll<HTMLElement>('.cta-fill, .cta-outline').forEach(btn => {
      btn.addEventListener('mousemove', e => {
        const r = btn.getBoundingClientRect();
        const x = (e.clientX - r.left - r.width  / 2) * 0.18;
        const y = (e.clientY - r.top  - r.height / 2) * 0.18;
        btn.style.transform = `translate(${x}px, ${y}px)`;
      });
      btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
    });
  }

  document.addEventListener('astro:page-load', () => {
    initLiveClock();
    initCanvas();
    initCounters();
    initTerminal();
    initScramble();
    initMagnetic();
  });
</script>
