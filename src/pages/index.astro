---
import Page from '@layouts/Page.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allProjects: CollectionEntry<'projects'>[] = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allWriteups: CollectionEntry<'writeups'>[] = await getCollection('writeups');
const recentWriteups = allWriteups
  .filter(w => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
const recentPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const allCertificates = await getCollection('certificates', c => !c.data.draft);
const recentCertificates = allCertificates
  .sort((a, b) => b.data.issueDate.getTime() - a.data.issueDate.getTime())
  .slice(0, 2);

const allSeries = await getCollection('series', s => !s.data.draft);
const seriesWithCounts = await Promise.all(
  allSeries.map(async (s) => {
    let count = 0;
    for (const item of s.data.items) {
      try {
        const entry = await getEntry(item.collection, item.slug);
        if (entry && !entry.data.draft) count++;
      } catch { /* skip */ }
    }
    return { series: s, count };
  })
);
const recentSeries = seriesWithCounts
  .filter(({ count }) => count > 0)
  .slice(0, 2);
---

<Page
  title="Obada Daghlas"
  description="Personal portfolio and content hub for Obada Daghlas — Cybersecurity Engineer & Software Engineer."
>
  <!-- ══════════════════════════════════ HERO ══════════════════════════════════ -->
  <section class="hero" id="hero">
    <!-- Animated canvas background -->
    <canvas class="hero-canvas" id="hero-canvas" aria-hidden="true"></canvas>

    <!-- Blueprint dot grid -->
    <div class="hero-dotgrid" aria-hidden="true"></div>

    <!-- Ghost watermark text -->
    <div class="hero-ghost" aria-hidden="true">DAGHLAS</div>

    <!-- Scan sweep line (plays once on load) -->
    <div class="hero-scan" aria-hidden="true"></div>

    <!-- Top metadata strip -->
    <div class="hero-meta" aria-hidden="true">
      <span class="hm-tag">SYS::PORTFOLIO.v2</span>
      <span class="hm-sep">·</span>
      <span class="hm-tag" id="live-time">––:––:––</span>
      <span class="hm-sep">·</span>
      <span class="hm-tag">33°N 36°E</span>
      <span class="hm-sep">·</span>
      <span class="hm-tag hm-status"><span class="hm-dot"></span>ONLINE</span>
    </div>

    <!-- Two-column hero body -->
    <div class="hero-body">
      <!-- LEFT: identity -->
      <div class="hero-l">
        <div class="avail-pill">
          <span class="avail-dot"></span>
          Open to opportunities
        </div>

        <h1 class="hero-name" data-text="Obada Daghlas">
          <span class="hn-line hn-first">Obada</span>
          <span class="hn-line hn-last">Daghlas</span>
        </h1>

        <p class="hero-roles">Cybersecurity Engineer · Software Engineer</p>

        <div class="term-wrap hero-term">
          <div class="term-chrome">
            <span class="tc-dot tc-r"></span>
            <span class="tc-dot tc-y"></span>
            <span class="tc-dot tc-g"></span>
            <span class="tc-label">~/obada — zsh</span>
          </div>
          <pre class="term-body"><code id="terminal-code"><span class="prompt">$</span> <span class="term-cursor blink">█</span></code></pre>
        </div>
      </div>

      <!-- RIGHT: portrait panel + content -->
      <div class="hero-r">
        <!-- Full-width photo panel -->
        <div class="hr-portrait">
          <img
            src={`${base}images/avatar2.png`}
            alt="Obada Daghlas"
            class="hr-img"
          />
          <div class="hr-shade" aria-hidden="true"></div>
          <div class="hr-scanlines" aria-hidden="true"></div>
          <span class="hrc hrc-tl" aria-hidden="true"></span>
          <span class="hrc hrc-tr" aria-hidden="true"></span>
        </div>

        <!-- Content below photo -->
        <div class="hr-info">
        <p class="hero-bio">
          I build full-stack systems and break web applications.
          Focused on web app security testing, secure backend engineering,
          and vulnerability research. BSc in Computer Systems Engineering.
        </p>

        <div class="hero-stats">
          <div class="hs-item">
            <div class="hs-num-row">
              <span class="hs-n" data-count="1">0</span><span class="hs-sfx">+</span>
            </div>
            <span class="hs-label">yrs coding</span>
          </div>
          <div class="hs-div"></div>
          <div class="hs-item">
            <div class="hs-num-row">
              <span class="hs-n" data-count="10">0</span><span class="hs-sfx">+</span>
            </div>
            <span class="hs-label">projects</span>
          </div>
          <div class="hs-div"></div>
          <div class="hs-item">
            <div class="hs-num-row">
              <span class="hs-n" data-count="5">0</span>
            </div>
            <span class="hs-label">certs</span>
          </div>
        </div>

        <div class="hero-ctas hero-cta">
          <a
            href="https://github.com/obadaDeg"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-fill"
          >GitHub ↗</a>
          <a
            href={`${base}Obada-Daghlas-CybersecurityEngineer.pdf`}
            target="_blank"
            rel="noopener noreferrer"
            class="cta-outline"
          >Resume ↗</a>
          <a href={`${base}contact`} class="cta-outline">Contact</a>
        </div>
        </div> <!-- /hr-info -->
      </div>
    </div>

    <!-- Bottom chip strip -->
    <div class="hero-chips">
      {['TypeScript','Go','Python','Bash','Astro','React','Node.js','PostgreSQL','Docker','Burp Suite','Metasploit','Linux'].map(s => (
        <span class="hero-chip">{s}</span>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════ SECTIONS ══════════════════════════════════ -->

  {featuredProjects.length > 0 && (
    <section class="ss animate-on-scroll">
      <header class="ss-hd">
        <div class="ss-title-g">
          <span class="ss-num">01</span>
          <h2 class="ss-h">Featured Projects</h2>
        </div>
        <a href={`${base}projects`} class="ss-more">All projects →</a>
      </header>
      <div class="proj-grid">
        {featuredProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            github={project.data.github}
            demo={project.data.demo}
            featured={project.data.featured}
          />
        ))}
      </div>
    </section>
  )}

  <section class="ss animate-on-scroll">
    <header class="ss-hd">
      <div class="ss-title-g">
        <span class="ss-num">02</span>
        <h2 class="ss-h">Recent Writeups</h2>
      </div>
      <a href={`${base}writeups`} class="ss-more">All writeups →</a>
    </header>
    {recentWriteups.length > 0 ? (
      <ul class="entry-list">
        {recentWriteups.map(w => (
          <li class="entry-row">
            <a href={`${base}writeups/${w.slug}`} class="er-title">{w.data.title}</a>
            <span class="er-tags">
              <span class="tag-src">{w.data.ctf}</span>
              <span class="tag-cat">{w.data.category}</span>
            </span>
            <time class="er-date">
              {w.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-msg">Writeups coming soon.</p>
    )}
  </section>

  <section class="ss animate-on-scroll">
    <header class="ss-hd">
      <div class="ss-title-g">
        <span class="ss-num">03</span>
        <h2 class="ss-h">Stack</h2>
      </div>
    </header>
    <div class="stack-tbl">
      {[
        { label: 'Languages', items: ['TypeScript', 'Go', 'Python', 'C', 'Bash'] },
        { label: 'Frontend',  items: ['Astro', 'React', 'Tailwind CSS'] },
        { label: 'Backend',   items: ['Node.js', 'Express', 'PostgreSQL', 'Redis', 'BullMQ', 'Drizzle ORM'] },
        { label: 'Security',  items: ['Burp Suite', 'Wireshark', 'nmap', 'OSINT', 'Metasploit'] },
        { label: 'DevOps',    items: ['Docker', 'GitHub Actions', 'Linux'] },
      ].map(g => (
        <div class="stack-row">
          <span class="st-cat">{g.label}</span>
          <div class="st-pills">
            {g.items.map(i => <span class="st-pill">{i}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="ss animate-on-scroll">
    <header class="ss-hd">
      <div class="ss-title-g">
        <span class="ss-num">04</span>
        <h2 class="ss-h">From the Blog</h2>
      </div>
      <a href={`${base}blog`} class="ss-more">All posts →</a>
    </header>
    {recentPosts.length > 0 ? (
      <ul class="entry-list">
        {recentPosts.map(post => (
          <li class="entry-row">
            <a href={`${base}blog/${post.slug}`} class="er-title">{post.data.title}</a>
            <span class="er-tags"></span>
            <time class="er-date">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-msg">Posts coming soon.</p>
    )}
  </section>

  {recentCertificates.length > 0 && (
    <section class="ss animate-on-scroll">
      <header class="ss-hd">
        <div class="ss-title-g">
          <span class="ss-num">05</span>
          <h2 class="ss-h">Certifications</h2>
        </div>
        <a href={`${base}certificates`} class="ss-more">All certs →</a>
      </header>
      <ul class="entry-list">
        {recentCertificates.map(cert => (
          <li class="entry-row">
            <a href={`${base}certificates/${cert.slug}`} class="er-title">{cert.data.title}</a>
            <span class="er-tags">
              <span class="tag-src">{cert.data.issuer}</span>
            </span>
            <time class="er-date">
              {cert.data.issueDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </time>
          </li>
        ))}
      </ul>
    </section>
  )}

  {recentSeries.length > 0 && (
    <section class="ss animate-on-scroll">
      <header class="ss-hd">
        <div class="ss-title-g">
          <span class="ss-num">06</span>
          <h2 class="ss-h">Learning Series</h2>
        </div>
        <a href={`${base}series`} class="ss-more">All series →</a>
      </header>
      <ul class="entry-list">
        {recentSeries.map(({ series: s, count }) => (
          <li class="entry-row entry-series">
            <div class="ser-main">
              <a href={`${base}series/${s.slug}`} class="er-title">{s.data.title}</a>
              <p class="ser-desc">{s.data.description}</p>
            </div>
            <span class="tag-cat er-date-right">{count} {count === 1 ? 'part' : 'parts'}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Page>

<style>
  /* ══ HERO ══ */
  .hero {
    position: relative;
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  /* Canvas node network */
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* Blueprint dot grid */
  .hero-dotgrid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(126, 255, 245, 0.18) 1px, transparent 1px);
    background-size: 44px 44px;
    background-position: 22px 22px;
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(ellipse 85% 70% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 85% 70% at 50% 50%, black 30%, transparent 100%);
  }

  /* Ghost watermark */
  .hero-ghost {
    position: absolute;
    bottom: -0.08em;
    right: -0.04em;
    font-family: 'Syne', sans-serif;
    font-size: clamp(5rem, 15vw, 12rem);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(126, 255, 245, 0.06);
    letter-spacing: -0.02em;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    line-height: 1;
    animation: ghost-fade-in 1.2s ease 0.8s both;
  }

  @keyframes ghost-fade-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Scan sweep */
  @keyframes scan-sweep {
    0%   { top: -1px; opacity: 0.9; }
    80%  { opacity: 0.6; }
    100% { top: 100%; opacity: 0; }
  }

  .hero-scan {
    position: absolute;
    left: 0;
    right: 0;
    top: -1px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-accent) 35%, #fff 50%, var(--color-accent) 65%, transparent 100%);
    box-shadow: 0 0 12px 2px rgba(126, 255, 245, 0.5);
    animation: scan-sweep 2.2s ease-in 0.3s forwards;
    pointer-events: none;
    z-index: 4;
  }

  /* Meta strip */
  .hero-meta {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-top: 1rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0;
    animation: fade-in 0.6s ease 2s forwards;
  }

  .hm-sep { opacity: 0.3; }

  .hm-status {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: rgba(74, 222, 128, 0.7);
  }

  .hm-dot {
    width: 5px;
    height: 5px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  /* Hero body 2-col grid */
  .hero-body {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 4rem;
    align-items: center;
    flex: 1;
    padding: 2.5rem 0 2rem;
  }

  /* LEFT column */
  .hero-l {
    min-width: 0;
  }

  .avail-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.68rem;
    color: rgba(74, 222, 128, 0.9);
    padding: 0.25rem 0.7rem 0.25rem 0.5rem;
    border: 1px solid rgba(74, 222, 128, 0.22);
    border-radius: 999px;
    letter-spacing: 0.04em;
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fade-up 0.5s ease 0.35s both;
  }

  .avail-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  /* Hero name */
  .hero-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
    cursor: default;
    display: block;
    position: relative;
  }

  .hn-line {
    display: block;
    overflow: hidden;
  }

  @keyframes name-wipe {
    from {
      clip-path: inset(0 100% 0 0);
      transform: translateX(-10px);
      opacity: 0;
    }
    to {
      clip-path: inset(0 0% 0 0);
      transform: translateX(0);
      opacity: 1;
    }
  }

  .hn-first { animation: name-wipe 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both; }
  .hn-last  { animation: name-wipe 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both; }

  /* Glitch on hover */
  .hero-name::before,
  .hero-name::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    letter-spacing: inherit;
  }

  .hero-name:hover::before {
    color: #ff3a5c;
    opacity: 0.75;
    text-shadow: 2px 0 #ff3a5c;
    animation: glitch-clip-1 0.35s steps(1) infinite;
  }

  .hero-name:hover::after {
    color: var(--color-accent);
    opacity: 0.75;
    text-shadow: -2px 0 var(--color-accent);
    animation: glitch-clip-2 0.35s steps(1) infinite 0.12s;
  }

  .hero-roles {
    font-size: 0.88rem;
    color: var(--color-accent);
    letter-spacing: 0.025em;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-up 0.5s ease 0.8s both;
  }

  /* Terminal */
  .term-wrap {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    opacity: 0;
    animation: fade-up 0.5s ease 0.95s both;
  }

  .term-chrome {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.85rem;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--color-border);
  }

  .tc-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .tc-r { background: #ff5f57; }
  .tc-y { background: #febc2e; }
  .tc-g { background: #28c840; }

  .tc-label {
    font-size: 0.67rem;
    color: var(--color-muted);
    margin: 0 auto;
    padding-right: 2.2rem;
  }

  .term-body {
    margin: 0;
    padding: 0.9rem 1.1rem;
    font-size: 0.78rem;
    color: var(--color-muted);
    overflow-x: hidden;
    white-space: pre-wrap;
    word-break: break-word;
    background: transparent;
  }

  .term-body code {
    font-family: 'IBM Plex Mono', monospace;
  }

  .prompt { color: var(--color-accent); }

  /* RIGHT column — full photo panel + content below */
  .hero-r {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 7px;
    overflow: hidden;
    opacity: 0;
    animation: fade-up 0.6s ease 0.55s both;
  }

  /* Photo area */
  .hr-portrait {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-bg);
  }

  .hr-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
    filter: drop-shadow(0 0 28px rgba(126, 255, 245, 0.12))
            drop-shadow(0 0 6px rgba(126, 255, 245, 0.06));
    transition: filter 0.4s ease;
  }

  .hr-portrait:hover .hr-img {
    filter: drop-shadow(0 0 36px rgba(126, 255, 245, 0.22))
            drop-shadow(0 0 10px rgba(126, 255, 245, 0.1));
  }

  /* Scanlines texture */
  .hr-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.04) 3px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  /* Atmospheric shade — bottom fade into hr-info + subtle teal glow at top */
  .hr-shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top,
        rgba(10,10,15,1)   0%,
        rgba(10,10,15,0.6) 15%,
        rgba(10,10,15,0.1) 40%,
        transparent        65%
      ),
      radial-gradient(ellipse 80% 60% at 50% 100%,
        rgba(126,255,245,0.05) 0%,
        transparent 70%
      );
    pointer-events: none;
    z-index: 1;
  }

  /* Corner brackets on photo */
  .hrc {
    position: absolute;
    width: 13px;
    height: 13px;
    border-color: rgba(126, 255, 245, 0.5);
    border-style: solid;
    z-index: 3;
  }
  .hrc-tl { top: 9px;  left: 9px;  border-width: 1px 0 0 1px; }
  .hrc-tr { top: 9px;  right: 9px; border-width: 1px 1px 0 0; }

  /* Content panel below photo */
  .hr-info {
    padding: 1.5rem 1.6rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-bio {
    font-size: 0.895rem;
    line-height: 1.9;
    color: var(--color-muted);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .hs-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hs-num-row {
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    line-height: 1;
  }

  .hs-n {
    font-family: 'Syne', sans-serif;
    font-size: 2.1rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    tabular-nums: proportional-nums;
  }

  .hs-sfx {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .hs-label {
    font-size: 0.62rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }

  .hs-div {
    width: 1px;
    height: 2.2rem;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-fill {
    display: inline-flex;
    align-items: center;
    padding: 0.58rem 1.3rem;
