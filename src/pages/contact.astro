---
import Page from '@layouts/Page.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Page
  title="Contact"
  description="Get in touch with Obada Daghlas — Cybersecurity Engineer and Software Engineer."
>
  <div class="ph">
    <span class="ph-eyebrow">SYS::CONTACT</span>
    <h1 class="ph-title">Contact</h1>
    <p class="ph-sub">
      Open to new opportunities, collaborations, and interesting conversations.
    </p>
  </div>

  <div class="contact-grid animate-on-scroll">
    <a
      href="https://github.com/obadaDeg"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-card"
    >
      <span class="cc-label">GitHub</span>
      <span class="cc-value">github.com/obadaDeg</span>
      <span class="cc-arrow">↗</span>
    </a>

    <a href="mailto:obada.daghlas.dev@gmail.com" class="contact-card">
      <span class="cc-label">Email</span>
      <span class="cc-value">obada.daghlas.dev@gmail.com</span>
      <span class="cc-arrow">↗</span>
    </a>

    <a
      href="https://linkedin.com/in/obadadaghlas"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-card"
    >
      <span class="cc-label">LinkedIn</span>
      <span class="cc-value">linkedin.com/in/obadadaghlas</span>
      <span class="cc-arrow">↗</span>
    </a>

    <a
      href={`${base}Obada-Daghlas-CybersecurityEngineer.pdf`}
      target="_blank"
      rel="noopener noreferrer"
      class="contact-card"
    >
      <span class="cc-label">Resume</span>
      <span class="cc-value">View PDF</span>
      <span class="cc-arrow">↗</span>
    </a>
  </div>

  <p class="ctf-note animate-on-scroll">
    For CTF collaboration or security research, GitHub is the best channel.
  </p>
</Page>

<style>
  .contact-grid {
    display: flex;
    flex-direction: column;
    margin-bottom: 3rem;
  }

  .contact-card {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    align-items: center;
    gap: 1.25rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: padding-left 0.18s ease;
  }

  .contact-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .contact-card:hover {
    padding-left: 0.5rem;
  }

  .cc-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .cc-value {
    font-size: 0.88rem;
    color: var(--color-text);
    transition: color 0.15s ease;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-card:hover .cc-value {
    color: var(--color-accent);
  }

  .cc-arrow {
    font-size: 0.9rem;
    color: var(--color-accent);
    opacity: 0;
    transition: opacity 0.15s ease;
    flex-shrink: 0;
  }

  .contact-card:hover .cc-arrow {
    opacity: 1;
  }

  .ctf-note {
    font-size: 0.8rem;
    color: var(--color-muted);
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    line-height: 1.7;
    max-width: 480px;
  }

  @media (max-width: 480px) {
    .contact-card {
      grid-template-columns: 72px 1fr auto;
      gap: 0.75rem;
    }
    .cc-value { font-size: 0.78rem; }
    .cc-arrow { opacity: 1; }
  }
</style>
