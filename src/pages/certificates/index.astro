---
import Page from '@layouts/Page.astro';
import CertificateCard from '@components/CertificateCard.astro';
import { getCollection } from 'astro:content';

const allCertificates = await getCollection('certificates', c => !c.data.draft);
const certificates = allCertificates.sort((a, b) =>
  b.data.issueDate.getTime() - a.data.issueDate.getTime()
);

const uniqueIssuers = new Set(certificates.map(c => c.data.issuer)).size;
const dates = certificates.map(c => c.data.issueDate);
const earliest = new Date(Math.min(...dates.map(d => d.getTime())));
const latest   = new Date(Math.max(...dates.map(d => d.getTime())));
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
const dateRange = earliest.getFullYear() === latest.getFullYear() && earliest.getMonth() === latest.getMonth()
  ? fmt(earliest)
  : `${fmt(earliest)} – ${fmt(latest)}`;

const CATEGORY_ORDER = ['Security', 'Development', 'DevOps', 'Other'] as const;
type Category = typeof CATEGORY_ORDER[number];

const grouped = new Map<Category, typeof certificates>();
for (const cat of CATEGORY_ORDER) grouped.set(cat, []);
for (const cert of certificates) grouped.get(cert.data.category as Category)!.push(cert);
const activeGroups = CATEGORY_ORDER.filter(cat => (grouped.get(cat)?.length ?? 0) > 0);
---

<Page title="Certificates" description="Formal credentials and ongoing education in cybersecurity and software engineering.">
  <div class="ph">
    <span class="ph-eyebrow">SYS::CERTIFICATES</span>
    <h1 class="ph-title">Certificates</h1>
    <p class="ph-sub">Formal credentials and ongoing education in cybersecurity and software engineering.</p>
    {certificates.length > 0 && (
      <span class="ph-stat">
        {certificates.length} certs · {uniqueIssuers} {uniqueIssuers === 1 ? 'issuer' : 'issuers'} · {dateRange}
      </span>
    )}
  </div>

  {certificates.length === 0 && (
    <p class="empty-msg">No certificates available yet.</p>
  )}

  {activeGroups.map((cat, i) => (
    <section class="cat-section animate-on-scroll">
      <div class="cat-header">
        <span class="cat-num">0{i + 1}</span>
        <h2 class="cat-title">{cat}</h2>
        <span class="cat-count">{grouped.get(cat)!.length}</span>
      </div>
      <div class="certs-grid">
        {grouped.get(cat)!.map(cert => (
          <CertificateCard
            title={cert.data.title}
            issuer={cert.data.issuer}
            date={cert.data.issueDate}
            slug={cert.slug}
            assetPath={cert.data.assetPath}
            skills={cert.data.skills}
            credentialUrl={cert.data.credentialUrl}
          />
        ))}
      </div>
    </section>
  ))}
</Page>

<style>
  .cat-section {
    margin-bottom: 3.5rem;
  }

  .cat-header {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--color-border);
  }

  .cat-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    opacity: 0.65;
  }

  .cat-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    flex: 1;
  }

  .cat-count {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    color: var(--color-muted);
  }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .certs-grid { grid-template-columns: 1fr; }
  }

  .empty-msg {
    color: var(--color-muted);
    font-style: italic;
    font-size: 0.875rem;
  }
</style>
